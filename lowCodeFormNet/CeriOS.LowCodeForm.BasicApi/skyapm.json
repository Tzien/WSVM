{
  "SkyWalking": {
    "ServiceName": "Demo",//该服务名称
    "Namespace": "",
    "HeaderVersions": [
      "sw8"
    ],
    "Sampling": {
      "SamplePer3Secs": -1,
      "Percentage": -1.0
    },
    //skywalking日志配置
